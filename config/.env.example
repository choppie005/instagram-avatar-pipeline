# Google Gemini API
GEMINI_API_KEY=xxxxx

# HeyGen (handles both avatar + voice)
HEYGEN_API_KEY=xxxxx

# D-ID (fallback for video generation)
DID_API_KEY=xxxxx

# Flux / fal.ai (for persona face generation)
FAL_API_KEY=xxxxx

# Instagram / Meta Graph API
INSTAGRAM_ACCESS_TOKEN=xxxxx
INSTAGRAM_USER_ID=xxxxx

# Optional: Discord webhook for failure notifications
DISCORD_WEBHOOK_URL=
